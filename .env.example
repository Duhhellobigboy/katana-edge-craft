# Stripe Price Mappings (Server-Side)
STRIPE_MICROSLIT_PRICE_ID=price_your-microslit-price-id
STRIPE_FUJISAN_PRICE_ID=price_your-fujisan-price-id
STRIPE_THUNDER_PRICE_ID=price_your-thunder-price-id
STRIPE_DOUBLE_SWIVEL_PRICE_ID=price_your-double-swivel-price-id
STRIPE_NARUTO_PRICE_ID=price_your-naruto-price-id
